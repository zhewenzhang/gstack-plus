{
  "name": "gstack-plus-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tier AI workflow orchestration. Add a model dispatch layer on top of role-based skill libraries.",
  "workspaces": [
    "site",
    "cli"
  ],
  "scripts": {
    "site:dev": "npm run dev --workspace site",
    "site:build": "npm run build --workspace site",
    "cli:dev": "npm run dev --workspace cli",
    "cli:build": "npm run build --workspace cli",
    "cli:test": "npm run test --workspace cli",
    "cli:try": "npm run cli:dev -- classify \"Sample task: rename a function\""
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "openai": "^6.36.0"
  }
}
