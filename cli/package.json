{
  "name": "gstack-plus",
  "version": "0.1.0",
  "description": "Multi-tier model orchestration CLI: classify tasks and route to the right Tier (A / Mid / Exec).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "gstack-plus": "./dist/index.js"
  },
  "files": ["dist", "templates", "README.md"],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node18 --clean --shims",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "vitest": "^1.4.0"
  }
}
